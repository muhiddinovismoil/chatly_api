generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChatType {
  DIRECT
  GROUP
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

model User {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email    String  @unique
  username String  @unique
  name     String
  password String?

  google_id String? @unique
  avatar    String?

  is_verified Boolean @default(false)

  two_factor_secret String?
  is_2fa_enabled    Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  chats    ChatMember[]
  messages Message[]

  sent_friends     Friend[] @relation("sent")
  received_friends Friend[] @relation("received")

  backup_codes BackupCode[]
  messageReads MessageRead[]
}

model BackupCode {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id String  @db.Uuid
  code    String
  is_used Boolean @default(false)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Friend {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requester String       @db.Uuid
  addressee String       @db.Uuid
  status    FriendStatus @default(PENDING)

  created_at DateTime @default(now())

  sender   User @relation("sent", fields: [requester], references: [id])
  receiver User @relation("received", fields: [addressee], references: [id])

  @@unique([requester, addressee])
}

model Chat {
  id   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type ChatType @default(DIRECT)
  name String?

  created_by String   @db.Uuid
  created_at DateTime @default(now())

  members  ChatMember[]
  messages Message[]
}

model ChatMember {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chat_id String @db.Uuid
  user_id String @db.Uuid

  role      String   @default("member")
  joined_at DateTime @default(now())

  last_read_message_id String? @db.Uuid

  chat Chat @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([chat_id, user_id])
}

model Message {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chat_id   String @db.Uuid
  sender_id String @db.Uuid

  type     MessageType @default(TEXT)
  content  String?
  file_url String?

  status String @default("SENT")

  is_edited  Boolean @default(false)
  is_deleted Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  chat   Chat @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  sender User @relation(fields: [sender_id], references: [id])

  reads MessageRead[]
}

model MessageRead {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  message_id String   @db.Uuid
  user_id    String   @db.Uuid
  read_at    DateTime @default(now())

  message Message @relation(fields: [message_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([message_id, user_id])
}
